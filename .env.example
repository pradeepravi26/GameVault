# Backend / database
# Set DB_ENV=local for local Docker MySQL, or DB_ENV=cloudsql for GCP Cloud SQL.
DB_ENV=local

# Shared DB settings
DB_USER=root
DB_PASSWORD=root
DB_NAME=game_vault
DB_CONNECTION_LIMIT=10

# Local Docker MySQL settings
DB_HOST=127.0.0.1
DB_PORT=3306

# Cloud SQL settings
# Example: my-gcp-project:us-central1:gamevault-mysql
CLOUD_SQL_CONNECTION_NAME=
# Optional override if you need a custom socket path
DB_SOCKET_PATH=

# Backend web origin / CORS
WEB_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
